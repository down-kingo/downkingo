  "private": true,
  "version": "3.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "i18n:extract": "bun x i18next-parser --config i18next-parser.config.js",
